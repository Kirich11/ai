{
    "$schema": "https://opencode.ai/config.json",
    "model": "github-copilot/claude-opus-4.6",
    "small_model": "github-copilot/claude-haiku-4.5",
    "instructions": [
        "~/Projects/ai/AGENTS.md",
        ".ai/context/*.md",
        ".ai.local/context/*.md"
    ],
    "skills": {
        "paths": ["~/Projects/ai/skills"]
    },
    "default_agent": "PO",
    "plugin": [
        "opencode-scheduler"
    ],
    "permission": {
        "edit": "allow",
        "read": {
            "*": "allow",
            "*.env": "deny",
            "*.env.*": "deny"
        },
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": {
            "*": "allow",
            "rm *": "ask",
            "sudo *": "ask"
        },
        "task": "allow",
        "external_directory": "deny",
        "todowrite": "allow",
        "todoread": "allow",
        "question": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "codesearch": "allow",
        "lsp": "allow",
        "doom_loop": "allow",
        "skill": "allow"
    },
    "watcher": {
        "ignore": [
            "node_modules/**",
            "vendor/**",
            "dist/**",
            "build/**",
            ".git/**",
            ".cache/**",
            "*no-vcs*",
            "*no-vcs*/**",
            "storage/**",
            ".idea/**",
            ".vscode/**",
            ".env*"
        ]
    },
    "agent": {
        "PO": {
            "mode": "primary",
            "description": "product owner",
            "model": "github-copilot/claude-opus-4.6",
            "prompt": "{file:~/Projects/ai/AGENTS.md}\n /caveman full \n USE ProductOwner agent",
            "permissions": {
                "write": true,
                "edit": true,
                "bash": true,
                "skill": {
                    "caveman": true
                }
            }
        },
        "Architect": {
            "mode": "subagent",
            "description": "architect",
            "model": "github-copilot/claude-opus-4.6",
            "prompt": "{file:~/Projects/ai/AGENTS.md}\n /caveman ultra \n USE ARCHITECT agent",
            "permissions": {
                "write": false,
                "edit": false,
                "bash": false,
                "skill": {
                    "caveman": true
                }
            }
        },
        "Critic": {
            "mode": "subagent",
            "description": "critic",
            "model": "github-copilot/claude-opus-4.6",
            "prompt": "{file:~/Projects/ai/AGENTS.md}\n /caveman ultra \n USE CRITIC agent",
            "permissions": {
                "write": false,
                "edit": false,
                "bash": false,
                "skill": {
                    "caveman": true
                }
            }
        },
        "Developer": {
            "mode": "subagent",
            "description": "developer",
            "model": "github-copilot/claude-opus-4.6",
            "prompt": "{file:~/Projects/ai/AGENTS.md}\n /caveman ultra \n USE Developer agent",
            "permissions": {
                "write": true,
                "edit": true,
                "bash": true,
                "skill": {
                    "caveman": true,
                    "create-use-case": true,
                    "create-git-worktree": true
                }
            }
        },
        "Tester": {
            "mode": "subagent",
            "description": "tester",
            "model": "github-copilot/claude-opus-4.6",
            "prompt": "{file:~/Projects/ai/AGENTS.md}\n /caveman ultra \n USE TESTER agent",
            "permissions": {
                "write": true,
                "edit": true,
                "bash": true,
                "skill": {
                    "caveman": true,
                    "create-use-case": false,
                    "create-git-worktree": false
                }
            }
        },
        "Reviewer": {
            "mode": "subagent",
            "description": "reviewer",
            "model": "github-copilot/claude-opus-4.6",
            "prompt": "{file:~/Projects/ai/AGENTS.md}\n /caveman ultra \n USE REVIEWER agent",
            "permissions": {
                "write": false,
                "edit": false,
                "bash": true,
                "skill": {
                    "caveman": true,
                    "create-use-case": false,
                    "create-git-worktree": false
                }
            }
        }
    }
}
